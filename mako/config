# Mako Notification Daemon

default-timeout=5000
anchor=bottom-right
layer=top
max-visible=5
on-button-left=dismiss

font=monospace 11
background-color=#00000033
text-color=#f5f5f5ff
progress-color=over #faebd780
width=500
height=80
border-size=2
border-radius=10,0,0,10
margin=0,-2,0,0
padding=5
max-icon-size=32
icon-location=left
sort=+time

[urgency=low]
border-color=#faebd780

[urgency=normal]
border-color=#faebd780

[urgency=critical]
border-color=#ee539680
